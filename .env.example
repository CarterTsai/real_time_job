KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=rocksdict-checkpoint-consumer
KAFKA_TOPICS=orders
KAFKA_AUTO_OFFSET_RESET=earliest

# Local RocksDB/RocksDict directory. In Kubernetes, mount this on persistent storage
# if you rely on it as the source of truth during restarts.
ROCKSDB_PATH=./data/checkpoints

# Flush checkpoint every N processed records or every X seconds, whichever comes first.
CHECKPOINT_EVERY_RECORDS=1000
CHECKPOINT_EVERY_SECONDS=5

# Optional: keep Kafka group offsets aligned with RocksDB checkpoints after RocksDB flush.
# This is still manual commit, not auto.commit.
COMMIT_KAFKA_OFFSETS=false

POLL_TIMEOUT_SECONDS=1.0
